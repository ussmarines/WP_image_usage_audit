<?xml version="1.0"?>
<ruleset name="Image Usage Audit">
	<description>WordPress coding standards and PHP 7.4 compatibility.</description>

	<file>image-usage-audit.php</file>
	<file>includes</file>
	<file>views</file>
	<file>uninstall.php</file>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>tests/*</exclude-pattern>

	<rule ref="WordPress-Extra">
		<!-- The plugin's required entrypoint intentionally contains its bootstrap class and function. -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName" />
		<exclude name="PSR1.Files.SideEffects.FoundWithSymbols" />
	</rule>
	<exclude name="PSR1.Files.SideEffects.FoundWithSymbols" />
	<rule ref="PHPCompatibilityWP">
		<properties>
			<property name="testVersion" value="7.4-" />
		</properties>
	</rule>
</ruleset>
